# Copier vers .env en local
SECRET_KEY=change-me-in-production
DEBUG=true
USE_SQLITE=true

# Render : DATABASE_URL est injecté automatiquement
# DATABASE_URL=postgresql://...

ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Render (API https://patermessager.onrender.com)
# ALLOWED_HOSTS=patermessager.onrender.com
# CORS_ALLOWED_ORIGINS=https://VOTRE-SITE-FRONT.onrender.com

CELERY_TASK_ALWAYS_EAGER=true
CELERY_BROKER_URL=redis://localhost:6379/0

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
OPENAI_API_KEY=

SUBSCRIPTION_PRICE_CENTS=990
SUBSCRIPTION_CURRENCY=usd

# Compte propriétaire (setup_owner)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=Admin@2026
DJANGO_SUPERUSER_EMAIL=admin@blackpater.app
